# Reference config values for the current tracked services.
# The active code reads Python config modules directly and does not
# automatically load this file at runtime.

#  -- Open Design --
#       Configuration from a single file (enviroment variables).
#       each service has their own config file as well. to default to if missing here
#



# ---------------------
# Ingestion settings --
#  
# ---------------------

SOURCE_NAME=bluesky
JETSTREAM_URLS=wss://jetstream1.us-east.bsky.network/subscribe,wss://jetstream2.us-east.bsky.network/subscribe,wss://jetstream1.us-west.bsky.network/subscribe,wss://jetstream2.us-west.bsky.network/subscribe
JETSTREAM_INDEX=3
RECONNECT_DELAY_SECONDS=5
MAX_RECONNECT_DELAY_SECONDS=60
RECONNECT_BACKOFF_MULTIPLIER=2
MAX_RECONNECT_ATTEMPTS_BEFORE_SWITCH=4


# ---------------------
# Broker settings --
# ---------------------

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SOCIAL_POSTS_TOPIC=BlueSky_socialmedia_posts
KAFKA_ACKS=all
KAFKA_PRODUCER_RETRIES=5
KAFKA_RETRY_BACKOFF_MS=1000
KAFKA_REQUEST_TIMEOUT_MS=30000
KAFKA_DELIVERY_TIMEOUT_MS=120000
KAFKA_SEND_TIMEOUT_SECONDS=10





# Shared logging
LOG_LEVEL=INFO


# Processing settings
POSTS_LAP=100
TOP_TERMS=20
MAX_EXAMPLES_PER_TOPIC=25
MAX_TRACKED_TOPICS=500
EXCLUDED_AUTHORS=did:plc:f4z2nftgrn75h7h3wucdyzaf

# Storage settings
TREND_SNAPSHOT_PATH=services/storage/logs/trends.json
TREND_EXAMPLE_POSTS_PATH=services/storage/logs/example_posts.json
