# Reference config values for the current tracked services.
# The active code reads Python config modules directly and does not
# automatically load this file at runtime.

# Shared broker settings
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SOCIAL_POSTS_TOPIC=BlueSky_socialmedia_posts

# Ingestion settings
SOURCE_NAME=bluesky
JETSTREAM_URL_1=wss://jetstream1.us-east.bsky.network/subscribe
JETSTREAM_URL_2=wss://jetstream2.us-east.bsky.network/subscribe
JETSTREAM_URL_3=wss://jetstream1.us-west.bsky.network/subscribe
JETSTREAM_URL_4=wss://jetstream2.us-west.bsky.network/subscribe
JETSTREAM_INDEX=3
LOCAL_SAMPLE_PATH=services/ingestion/logs/post_dump.json
MAX_SAMPLE_POSTS=200

# Processing settings
POSTS_LAP=100
TOP_TERMS=20
EXCLUDED_AUTHORS=did:plc:f4z2nftgrn75h7h3wucdyzaf

# Storage settings
TREND_SNAPSHOT_PATH=services/storage/logs/trends.json
TREND_EXAMPLE_POSTS_PATH=services/storage/logs/example_posts.json
