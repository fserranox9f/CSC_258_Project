# Project-wide path override
PROJECT_ROOT=

# Producer settings
JETSTREAM_URL=wss://jetstream1.us-east.bsky.network/subscribe?wantedCollections=app.bsky.feed.post
SOURCE_NAME=bluesky
SAVE_SAMPLE_PATH=storage/data/sample_post.json
MAX_SAMPLE_POSTS=10000
RECONNECT_DELAY_SECONDS=5

# Trend service settings
TREND_DATA_PATH=storage/data/sample_post.json
TREND_WINDOW_SIZE=1000
TREND_TOP_K=5
TREND_SERVICE_HOST=0.0.0.0
TREND_SERVICE_PORT=5000
TREND_SERVICE_DEBUG=true
